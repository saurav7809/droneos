# ═══════════════════════════════════════════════════════════════
# DroneOS — Environment Configuration
# COPY this file to .env and fill in real values before deploying
# NEVER commit .env to version control!
# ═══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
POSTGRES_DB=dronedb
DB_USERNAME=droneos
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ── Security ──────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_64

# ── App ───────────────────────────────────────────────────────
FRONTEND_PORT=80
TAG=latest
TZ=Asia/Kolkata

# ── Data storage (for production volume mounts) ───────────────
DATA_DIR=/opt/droneos/data

# ── PgAdmin (optional debug profile) ─────────────────────────
PGADMIN_EMAIL=admin@droneos.local
PGADMIN_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD
